# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow
DB_USER=taskflow
DB_PASSWORD=taskflow

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=taskflow

# Server
SERVER_PORT=8080

# pgAdmin
PGADMIN_EMAIL=admin@taskflow.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Telegram (fill in before running the bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
# URL мини-апп (HTTPS), например https://yourdomain.com
# Если задан — бот автоматически ставит кнопку меню и отправляет её в /start
MINIAPP_URL=

# Groq API
GROQ_API_KEY=

# JWT
JWT_SECRET=changeme-in-production
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30
